<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.fara7.bmi.BMIController"
            prefWidth="500" prefHeight="640"
            style="-fx-background-color: linear-gradient(to bottom, #1a2a4a, #2e4a7a);">

    <VBox spacing="14"
          AnchorPane.topAnchor="20"
          AnchorPane.leftAnchor="20"
          AnchorPane.rightAnchor="20"
          AnchorPane.bottomAnchor="20"
          style="-fx-background-color: rgba(255,255,255,0.07);
                 -fx-background-radius: 16;
                 -fx-padding: 20;">

        <Label text="Body Mass Index"
               maxWidth="Infinity" alignment="CENTER"
               style="-fx-font-size: 26;
                      -fx-font-weight: bold;
                      -fx-text-fill: #FFD700;
                      -fx-font-family: 'Segoe UI';"/>

        <Separator style="-fx-background-color: #FFD700;"/>

        <GridPane hgap="12" vgap="14">
            <columnConstraints>
                <ColumnConstraints minWidth="110"/>
                <ColumnConstraints minWidth="240"/>
            </columnConstraints>

            <Label text="Gender:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                   style="-fx-font-weight: bold; -fx-text-fill: #FFD700; -fx-font-size: 13;"/>
            <HBox spacing="20" GridPane.rowIndex="0" GridPane.columnIndex="1" alignment="CENTER_LEFT">
                <RadioButton text="Male" fx:id="maleRadio" selected="true"
                             style="-fx-text-fill: white; -fx-font-size: 13;"/>
                <RadioButton text="Female" fx:id="femaleRadio"
                             style="-fx-text-fill: white; -fx-font-size: 13;"/>
            </HBox>

            <Label text="Age:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                   style="-fx-font-weight: bold; -fx-text-fill: #FFD700; -fx-font-size: 13;"/>
            <TextField fx:id="ageField" promptText="e.g. 25" prefWidth="220"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"
                       style="-fx-background-color: rgba(255,255,255,0.15);
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: #aaa;
                              -fx-background-radius: 8;
                              -fx-border-color: #FFD700;
                              -fx-border-radius: 8;
                              -fx-padding: 6;"/>

            <Label text="Length (cm):" GridPane.rowIndex="2" GridPane.columnIndex="0"
                   style="-fx-font-weight: bold; -fx-text-fill: #FFD700; -fx-font-size: 13;"/>
            <TextField fx:id="lengthField" promptText="e.g. 175" prefWidth="220"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"
                       style="-fx-background-color: rgba(255,255,255,0.15);
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: #aaa;
                              -fx-background-radius: 8;
                              -fx-border-color: #FFD700;
                              -fx-border-radius: 8;
                              -fx-padding: 6;"/>

            <Label text="Weight (kg):" GridPane.rowIndex="3" GridPane.columnIndex="0"
                   style="-fx-font-weight: bold; -fx-text-fill: #FFD700; -fx-font-size: 13;"/>
            <TextField fx:id="weightField" promptText="e.g. 80" prefWidth="220"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"
                       style="-fx-background-color: rgba(255,255,255,0.15);
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: #aaa;
                              -fx-background-radius: 8;
                              -fx-border-color: #FFD700;
                              -fx-border-radius: 8;
                              -fx-padding: 6;"/>

            <Label text="Activity:" GridPane.rowIndex="4" GridPane.columnIndex="0"
                   style="-fx-font-weight: bold; -fx-text-fill: #FFD700; -fx-font-size: 13;"/>
            <ComboBox fx:id="activityCombo" prefWidth="220"
                      GridPane.rowIndex="4" GridPane.columnIndex="1"
                      style="-fx-background-color: rgba(255,255,255,0.15);
                             -fx-border-color: #FFD700;
                             -fx-border-radius: 8;
                             -fx-background-radius: 8;"/>
        </GridPane>

        <Separator style="-fx-background-color: #FFD700;"/>

        <HBox spacing="24" alignment="CENTER">
            <Button text="Calc" fx:id="calcBtn" onAction="#handleCalc"
                    prefWidth="110" prefHeight="36"
                    style="-fx-background-color: linear-gradient(to bottom, #FFD700, #FFA500);
                           -fx-text-fill: #1a2a4a;
                           -fx-font-weight: bold;
                           -fx-font-size: 14;
                           -fx-background-radius: 10;
                           -fx-cursor: hand;"/>
            <Button text="New" fx:id="newBtn" onAction="#handleNew"
                    prefWidth="110" prefHeight="36"
                    style="-fx-background-color: linear-gradient(to bottom, #FFD700, #FFA500);
                           -fx-text-fill: #1a2a4a;
                           -fx-font-weight: bold;
                           -fx-font-size: 14;
                           -fx-background-radius: 10;
                           -fx-cursor: hand;"/>
        </HBox>

        <Separator style="-fx-background-color: #FFD700;"/>

        <CheckBox text="Display Image" fx:id="displayImageCheck" onAction="#handleCheckBox"
                  style="-fx-text-fill: white; -fx-font-size: 13;"/>

        <HBox spacing="30" alignment="CENTER_LEFT">
            <VBox spacing="10">
                <Label fx:id="bmiLabel"
                       style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #00FF99;"/>
                <Label fx:id="caloriesLabel"
                       style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: #FFD700;"/>
            </VBox>
            <ImageView fx:id="bodyImage" fitWidth="120" fitHeight="120"
                       visible="false" preserveRatio="true"/>
        </HBox>

        <Hyperlink text="Click Me!" fx:id="clickMe" onAction="#handleHyperlink"
                   style="-fx-text-fill: #FFD700;
                          -fx-font-weight: bold;
                          -fx-font-size: 15;
                          -fx-border-color: transparent;"/>

    </VBox>
</AnchorPane>